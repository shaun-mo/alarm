<Window x:Class="SunriseAlarm.App.SunriseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sunrise" WindowStyle="None" WindowState="Maximized"
        ResizeMode="NoResize" Topmost="True" Background="Black">
    <Grid>
        <Border>
            <Border.Background>
                <SolidColorBrush x:Name="BackdropBrush" Color="#000000" />
            </Border.Background>
        </Border>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"
                    HorizontalAlignment="Center" Margin="0,0,0,90">
            <Button x:Name="SnoozeButton" Content="Snooze" Width="180" Height="72"
                    FontSize="22" Margin="0,0,28,0" Click="SnoozeButton_Click" />
            <Button x:Name="DismissButton" Content="Stop" Width="180" Height="72"
                    FontSize="22" Click="DismissButton_Click" />
        </StackPanel>
    </Grid>
</Window>
